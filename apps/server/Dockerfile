FROM oven/bun:1.3.12 AS builder
WORKDIR /app

ARG DATABASE_URL
ARG BETTER_AUTH_SECRET
ARG BETTER_AUTH_URL
ARG REDIS_URL
ARG GITHUB_CLIENT_ID
ARG GITHUB_CLIENT_SECRET
ARG GOOGLE_CLIENT_ID
ARG GOOGLE_CLIENT_SECRET
ARG DISCORD_TOKEN
ARG DISCORD_APP_ID
ARG SANITY_API_TOKEN
ARG SANITY_PROJECT_ID
ARG SANITY_DATASET
ARG SANITY_API_VERSION
ARG RABBITMQ_URL
ARG RABBITMQ_QUEUE
ARG CORS_ORIGIN
ARG NEXT_PUBLIC_SERVER_URL

ENV DATABASE_URL=$DATABASE_URL \
    BETTER_AUTH_SECRET=$BETTER_AUTH_SECRET \
    BETTER_AUTH_URL=$BETTER_AUTH_URL \
    REDIS_URL=$REDIS_URL \
    GITHUB_CLIENT_ID=$GITHUB_CLIENT_ID \
    GITHUB_CLIENT_SECRET=$GITHUB_CLIENT_SECRET \
    GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID \
    GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET \
    DISCORD_TOKEN=$DISCORD_TOKEN \
    DISCORD_APP_ID=$DISCORD_APP_ID \
    SANITY_API_TOKEN=$SANITY_API_TOKEN \
    SANITY_PROJECT_ID=$SANITY_PROJECT_ID \
    SANITY_DATASET=$SANITY_DATASET \
    SANITY_API_VERSION=$SANITY_API_VERSION \
    RABBITMQ_URL=$RABBITMQ_URL \
    RABBITMQ_QUEUE=$RABBITMQ_QUEUE \
    CORS_ORIGIN=$CORS_ORIGIN \
    NEXT_PUBLIC_SERVER_URL=$NEXT_PUBLIC_SERVER_URL

COPY . .

RUN bun install --frozen-lockfile
RUN bunx turbo build --filter=server

FROM oven/bun:1.3.12 AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

COPY --from=builder /app/apps/server/dist ./apps/server/dist
COPY --from=builder /app/apps/server/package.json ./apps/server/package.json

EXPOSE 3000

CMD ["bun", "apps/server/dist/index.mjs"]